@echo off
echo ================= GIT WORKFLOW =================
echo.
echo Check status:
echo git status
echo.
echo Add changes:
echo git add .
echo.
echo Commit changes:
echo git commit -m "message"
echo.
echo Push to GitHub:
echo git push origin main
echo.
echo Pull latest changes:
echo git pull origin main
echo.
echo Clone repository:
echo git clone https://github.com/username/repository.git
echo.
echo Check branches:
echo git branch
echo.
echo Create new branch:
echo git checkout -b branch-name
echo.
echo Switch branch:
echo git checkout branch-name
echo.
echo View commit history:
echo git log
echo.
echo ================================================
pause